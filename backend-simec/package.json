{
  "name": "simec-backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "npx prisma migrate deploy && node server.js",
    "start:prod": "npx prisma migrate deploy && node server.js",
    "pretest": "prisma generate",
    "seed": "node seed.js",
    "tenant:maintenance": "node scripts/tenantOperationalMaintenance.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:push": "npx prisma db push",
    "prisma:reset": "npx prisma db push --force-reset && npm run seed",
    "test": "node --test --experimental-test-isolation=none tests/**/*.test.js",
    "test:agent": "node --test --experimental-test-isolation=none tests/agent/agentCore.test.js",
    "test:auth": "node --test --experimental-test-isolation=none tests/auth/*.test.js",
    "test:risk": "node --test --experimental-test-isolation=none tests/risk/*.test.js"
  },
  "prisma": {
    "seed": "node seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.9.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.3",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.9.0"
  }
}
