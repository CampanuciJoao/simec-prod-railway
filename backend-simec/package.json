{
  "name": "simec-backend",
  "version": "1.0.1",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "postinstall": "node -e \"if(process.env.GEHC_SCRAPER_ENABLED === 'true'){require('child_process').execSync('npx playwright install --with-deps chromium',{stdio:'inherit'})}else{console.log('[postinstall] Playwright ignorado — defina GEHC_SCRAPER_ENABLED=true para instalar.')}\"",
    "start": "node scripts/migrate.mjs && node server.js",
    "start:server": "node scripts/migrate.mjs && node server.js",
    "start:worker": "node worker.js",
    "start:prod": "node scripts/migrate.mjs && node server.js",
    "pretest": "prisma generate",
    "seed": "node seed.js",
    "tenant:maintenance": "node scripts/tenantOperationalMaintenance.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:push": "npx prisma db push",
    "prisma:reset": "npx prisma db push --force-reset && npm run seed",
    "test": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/**/*.test.js",
    "test:agent": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/agentCore.test.js",
    "test:os": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/osCorretivaAgent.test.js",
    "test:flow": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/osCorretivaFlow.test.js",
    "test:action": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/actionResolver.test.js",
    "test:scoring": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/entityScoring.test.js",
    "test:state": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/agent/agendamentoState.test.js",
    "test:auth": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/auth/*.test.js",
    "test:risk": "node --env-file=tests/.env.test --test --experimental-test-isolation=none tests/risk/*.test.js"
  },
  "prisma": {
    "seed": "node seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.9.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "graphql-ws": "^6.0.8",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.3",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^4.10.38",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.9.0"
  }
}
