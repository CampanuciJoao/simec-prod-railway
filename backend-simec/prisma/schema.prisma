// ─── GE Health Cloud — Documentos PDF de OS (insumo bruto para IA) ───────────
//
// Cada OS GE pode ter 1+ documentos (Relatório de Serviço principal e anexos),
// expostos pelo portal MyEquipment 360 via popup "Documentos disponíveis".
// Captura é feita por Playwright autenticado (gehcDocumentDownloader.js) que
// marca um documento por vez (evita o ZIP que aparece com múltiplos selecionados),
// faz upload pro Cloudflare R2 e persiste a referência aqui.
//
// A extração de causa-raiz, medições e ações estruturadas acontece em PR
// posterior, lendo os PDFs deste storage. PDFs ficam armazenados permanentemente
// para permitir reprocessamento quando o extrator melhorar.

model GehcPdfDocumento {
  id              String   @id @default(uuid())
  tenantId        String
  equipamentoId   String   @map("equipamento_id")
  ordemServicoId  String   @map("ordem_servico_id")

  // Identidade do documento no portal GE (ex: "069Ur00000YSvPeIAL").
  documentId      String   @unique @map("document_id")
  fileName        String   @map("file_name")
  fileHash        String?  @map("file_hash")
  fileSizeBytes   Int?     @map("file_size_bytes")

  // Chave do objeto no Cloudflare R2 (gehc-pdfs/{tenant}/{os}/{docId}.pdf).
  r2Key           String?  @map("r2_key")

  baixadoEm       DateTime? @map("baixado_em")
  tentativas      Int       @default(0)
  ultimoErro      String?   @db.Text @map("ultimo_erro")
  ultimaTentativaEm DateTime? @map("ultima_tentativa_em")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento  Equipamento      @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)
  ordemServico GehcOrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  extraido     GehcPdfExtraido?

  @@index([tenantId, equipamentoId])
  @@index([tenantId, ordemServicoId])
  @@index([baixadoEm])
  @@map("gehc_pdf_documentos")
}

// ─── GE Health Cloud — Extração estruturada do PDF (insumo direto da IA) ─────
//
// 1:1 com GehcPdfDocumento. Camada 1 (regex sobre texto cru) + Camada 2 (LLM
// normaliza causa-raiz em taxonomia + extrai medições/peças). Versionada para
// permitir reprocessamento quando o extrator melhorar.
//
// Taxonomia atual de root_cause_category (string-based, evolui sem migration):
//   - infra_chiller_cliente   - falha de chiller predial do hospital
//   - cryo_compressor          - compressor do criostato (LCC, helium)
//   - magneto_helio            - nivel/pressao de helio fora de spec
//   - bobina                   - bobinas (corpo, cabeça, etc)
//   - gradiente                - amplificador/sistema de gradiente
//   - rf                       - cadeia RF (transmissor/receptor)
//   - mesa_mecanica            - mesa do paciente (correia, motor)
//   - software                 - falha de SW/host/MRU
//   - rede_dados               - conectividade, DICOM, fluxo de imagem
//   - infra_eletrica           - energia, no-break, aterramento
//   - desconhecido             - LLM nao conseguiu categorizar com confianca

model GehcPdfExtraido {
  id              String  @id @default(uuid())
  tenantId        String
  pdfDocumentoId  String  @unique @map("pdf_documento_id")

  // Camada 1: regex
  caseNumber       String?  @map("case_number")
  woNumber         String?  @map("wo_number")
  serviceType      String?  @map("service_type")
  equipmentStatus  String?  @map("equipment_status")
  systemId         String?  @map("system_id")
  serialNumber     String?  @map("serial_number")
  engineerFullName String?  @map("engineer_full_name")
  problemReported  String?  @db.Text @map("problem_reported")
  problemAnalyzed  String?  @db.Text @map("problem_analyzed")
  actionsTaken     String?  @db.Text @map("actions_taken")
  rootCauseRaw     String?  @db.Text @map("root_cause_raw")
  testsPerformed   String?  @db.Text @map("tests_performed")
  totalMinutes     Int?     @map("total_minutes")
  openedAt         DateTime? @map("opened_at")

  // Camada 2: LLM
  rootCauseCategory String?  @map("root_cause_category")
  measurementsJson  Json?    @map("measurements_json")
  partsReplacedJson Json?    @map("parts_replaced_json")
  llmExtractedAt    DateTime? @map("llm_extracted_at")
  llmModel          String?  @map("llm_model")
  llmError          String?  @db.Text @map("llm_error")

  // Versionamento
  extractorVersion  Int      @default(1) @map("extractor_version")
  rawTextHash       String?  @map("raw_text_hash")
  extractionError   String?  @db.Text @map("extraction_error")
  extraidoEm        DateTime? @map("extraido_em")
  tentativas        Int      @default(0)
  ultimaTentativaEm DateTime? @map("ultima_tentativa_em")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pdfDocumento GehcPdfDocumento @relation(fields: [pdfDocumentoId], references: [id], onDelete: Cascade)

  @@index([tenantId, rootCauseCategory])
  @@index([tenantId, extraidoEm])
  @@index([extractorVersion, extraidoEm])
  @@map("gehc_pdf_extraidos")
}

// ─── IA — Estado dos pipelines automáticos ───────────────────────────────────
//
// Kill switch global da IA + pausa cirúrgica por pipeline. Workers checam o
// estado relevante antes de processar; se ativo=false, registram log e pulam.
// tenantId NULL representa estado global aplicável a todos os tenants — útil
// para freio de emergência ou janelas de manutenção.
//
// Convenção de nomes do campo `pipeline`:
//   - "global"            → kill switch geral, afeta todos os pipelines
//   - "gehc_captura_pdf"  → captura via Playwright (PR atual)
//   - "gehc_extracao_pdf" → extração estruturada (PR futuro)
//   - "knowledge_layer"   → consolidação de eventos (PR futuro)

// ─── Knowledge Layer — timeline unificada de eventos por equipamento ────────
//
// Materializacao read-only mantida pelo knowledgeLayerSync. Recebe entradas de
// 5 produtores (PDF GE extraido, telemetria GE, OS interna SIMEC, visita de
// terceiro, alerta de saude) num formato comum, para que o modelo preditivo e
// o RAG do chatbot consumam tudo com uma unica query.
//
// Convencoes:
//   fonte: 'pdf_ge' | 'telemetria_ge' | 'os_simec' | 'visita_terceiro' | 'alerta_telemetria'
//   tipoEvento: subtipo dentro da fonte (ex: 'corretiva_ge', 'pm_ge',
//     'anomalia_helio', 'compressor_off', 'os_aberta', 'os_concluida',
//     'visita_agendada', 'visita_concluida', 'alerta_helio_critico')
//   severidade: 'info' | 'low' | 'medium' | 'high' | 'critical'
//   refFonteTipo + refFonteId: ponteiro auditavel para a linha original
//
// Idempotencia garantida pelo unique (refFonteTipo, refFonteId, tipoEvento).
// Podemos truncar e reconstruir sem perda — fonte de verdade fica nas tabelas
// originais.

model EventoEquipamento {
  id             String   @id @default(uuid())
  tenantId       String
  equipamentoId  String   @map("equipamento_id")

  ocorridoEm     DateTime @map("ocorrido_em")
  fonte          String
  tipoEvento     String   @map("tipo_evento")
  severidade     String   @default("info")
  causaCategoria String?  @map("causa_categoria")
  resumo         String
  detalhesJson   Json?    @map("detalhes_json")

  refFonteTipo   String   @map("ref_fonte_tipo")
  refFonteId     String   @map("ref_fonte_id")

  createdAt      DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento Equipamento @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)
  embedding   EventoEquipamentoEmbedding?

  @@unique([refFonteTipo, refFonteId, tipoEvento], name: "evento_equipamento_origem_tipo")
  @@index([tenantId, equipamentoId, ocorridoEm(sort: Desc)])
  @@index([tenantId, fonte, ocorridoEm(sort: Desc)])
  @@index([tenantId, causaCategoria])
  @@index([tenantId, severidade, ocorridoEm(sort: Desc)])
  @@map("evento_equipamento")
}

// ─── Embeddings dos eventos (para RAG e busca por similaridade) ─────────────
//
// 1:1 com EventoEquipamento. Embedding salvo como JSONB array de floats —
// suficiente para datasets ate ~10k eventos com calculo de similaridade na
// aplicacao. Migracao para pgvector sera PR isolado quando a frota crescer.

model EventoEquipamentoEmbedding {
  id                  String   @id @default(uuid())
  tenantId            String
  eventoEquipamentoId String   @unique @map("evento_equipamento_id")

  embedding           Json     // array de N floats (N = dim)
  model               String
  dim                 Int
  inputText           String   @db.Text @map("input_text")

  geradoEm            DateTime @default(now()) @map("gerado_em")
  createdAt           DateTime @default(now())

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evento              EventoEquipamento @relation(fields: [eventoEquipamentoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("evento_equipamento_embedding")
}

// ─── Insights da IA — recomendacoes derivadas dos padroes ───────────────────
//
// Saidas do worker preditivo. 1 insight ativo por (equipamento, tipo) — quando
// regerado, atualiza. Resolvido fica quando o problema sai do radar (ex: helio
// volta ao normal, OS preventiva foi feita).
//
// feedback_util captura "thumbs up/down" do engenheiro — vira ground truth
// para retreinamento futuro.

model IaInsight {
  id            String    @id @default(uuid())
  tenantId      String
  equipamentoId String    @map("equipamento_id")

  tipo          String    // 'reincidencia_causa' | 'anomalia_helio' | 'risco_alto' | etc
  severidade    String    @default("medium")
  titulo        String
  descricao     String    @db.Text
  recomendacao  String?   @db.Text
  evidenciaJson Json?     @map("evidencia_json")

  geradoEm      DateTime  @default(now()) @map("gerado_em")
  validoAte     DateTime? @map("valido_ate")
  resolvidoEm   DateTime? @map("resolvido_em")
  feedbackUtil  Boolean?  @map("feedback_util")
  feedbackEm    DateTime? @map("feedback_em")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento   Equipamento @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, severidade, geradoEm(sort: Desc)])
  @@index([tenantId, resolvidoEm])
  @@map("ia_insights")
}

