generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  nome      String
  slug      String   @unique
  timezone  String   @default("UTC")
  locale    String   @default("pt-BR")
  ativo     Boolean  @default(true)
  contatoNome String?
  contatoEmail String?
  contatoTelefone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios             Usuario[]
  unidades             Unidade[]
  equipamentos         Equipamento[]
  veiculos             Veiculo[]
  acessorios           Acessorio[]
  contratos            Contrato[]
  manutencoes          Manutencao[]
  seguros              Seguro[]
  alertas              Alerta[]
  alertasLidos         AlertaLidoPorUsuario[]
  alertasHistorico     AlertaHistorico[]
  logsAuditoria        LogAuditoria[]
  anexos               Anexo[]
  notasAndamento       NotaAndamento[]
  emailsNotificacao    EmailNotificacao[]
  notificacoesEnviadas NotificacaoEnviada[]
  agentSessions        AgentSession[]
  agentMessages        AgentMessage[]
  userAgentMemories    UserAgentMemory[]
  manutencaoEventos    ManutencaoEvento[]
  historicoAtivoEventos HistoricoAtivoEvento[]
  authSessions         AuthSession[]
  passwordResetTokens  PasswordResetToken[]
  orcamentos           Orcamento[]
  osCorretivas         OsCorretiva[]
  visitasTerceiro      VisitaTerceiro[]
  gehcSaudeSnapshots   GehcSaudeSnapshot[]
  gehcToken            GehcToken?
  gehcContratos        GehcContrato[]
  gehcOrdensServico    GehcOrdemServico[]
  gehcUtilizacao       GehcUtilizacaoMensal[]
  gehcAlertaSuspensoes     GehcAlertaSuspensao[]
  gehcPdfDocumentos        GehcPdfDocumento[]
  gehcPdfExtraidos         GehcPdfExtraido[]
  eventosEquipamento       EventoEquipamento[]
  eventoEmbeddings         EventoEquipamentoEmbedding[]
  iaInsights               IaInsight[]
  telegramNotificacoes     TelegramNotificacao[]
  telegramVinculacaoTokens TelegramVinculacaoToken[]
  alertConfigs             AlertConfig[]
  aiPipelineEstados        AiPipelineEstado[]

  @@map("tenants")
}

model AlertConfig {
  id        String   @id @default(uuid())
  tenantId  String
  module    String
  config    Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
  @@map("alert_configs")
}

model Unidade {
  id           String   @id @default(uuid())
  tenantId     String
  nomeSistema  String
  nomeFantasia String?
  cnpj         String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  timezone     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  anexos            Anexo[]
  equipamentos      Equipamento[]
  veiculos          Veiculo[]
  segurosCobertos   Seguro[]      @relation("SegurosUnidadesCobertas")
  contratosCobertos Contrato[]    @relation("ContratosUnidadesCobertas")
  orcamentos        Orcamento[]

  @@unique([tenantId, nomeSistema])
  @@unique([tenantId, cnpj])
  @@unique([tenantId, id])
  @@index([tenantId, cidade])
  @@index([tenantId, timezone])
  @@map("unidades")
}

model Usuario {
  id        String   @id @default(uuid())
  tenantId  String
  username  String
  email     String
  nome      String
  senha     String
  role      Role     @default(user)
  timezone  String?
  notificacoesBaselineEm DateTime @default(now()) @map("notificacoes_baseline_em")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alertasLidos         AlertaLidoPorUsuario[]
  logsDeAuditoria      LogAuditoria[]
  notasDeAndamento     NotaAndamento[]
  osCorretivas         OsCorretiva[]
  manutencaoEventos    ManutencaoEvento[]
  authSessions         AuthSession[]
  passwordResetTokens  PasswordResetToken[]
  orcamentosComoCriador   Orcamento[] @relation("OrcamentoCriador")
  orcamentosComoAprovador Orcamento[] @relation("OrcamentoAprovador")
  aiPipelinesPausados     AiPipelineEstado[] @relation("AiPipelinePausadoPor")
  aiPipelinesRetomados    AiPipelineEstado[] @relation("AiPipelineRetomadoPor")

  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@unique([tenantId, id])
  @@index([tenantId, role])
  @@map("usuarios")
}

model Equipamento {
  id               String            @id @default(uuid())
  tenantId         String
  tag              String
  modelo           String
  tipo             String?
  setor            String?
  apelido          String?
  fabricante       String?
  anoFabricacao    String?           @map("ano_fabricacao")
  dataInstalacao   DateTime?         @map("data_instalacao")
  status           StatusEquipamento @default(Operante)
  numeroPatrimonio String?           @map("numero_patrimonio")
  registroAnvisa   String?           @map("registro_anvisa")
  aeTitle          String?           @map("ae_title")
  telefoneSuporte  String?           @map("telefone_suporte")
  observacoes      String?
  unidadeId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unidade           Unidade      @relation(fields: [tenantId, unidadeId], references: [tenantId, id], onDelete: Cascade)
  acessorios        Acessorio[]
  anexos            Anexo[]
  manutencoes       Manutencao[]
  osCorretivas      OsCorretiva[]
  seguros           Seguro[]
  contratosCobertos Contrato[]   @relation("ContratosEquipamentosCobertos")
  historicoEventos  HistoricoAtivoEvento[]

  riskScore     Int?
  riskLevel     String?
  riskUpdatedAt DateTime?

  gehcAssetId        String?  @map("gehc_asset_id")
  gehcSystemId       String?  @map("gehc_system_id")
  gehcSaudeSnapshots GehcSaudeSnapshot[]
  gehcContrato       GehcContrato?
  gehcOrdensServico  GehcOrdemServico[]
  gehcUtilizacao     GehcUtilizacaoMensal[]
  gehcPdfDocumentos  GehcPdfDocumento[]
  eventosEquipamento EventoEquipamento[]
  iaInsights         IaInsight[]

  @@unique([tenantId, tag])
  @@unique([tenantId, aeTitle])
  @@unique([tenantId, id])
  @@index([tenantId, unidadeId, status])
  @@index([tenantId, aeTitle])
  @@index([tenantId, modelo])
  @@index([tenantId, tipo])
  @@index([tenantId, fabricante])
  @@index([tenantId, numeroPatrimonio])
  @@map("equipamentos")
}

model Veiculo {
  id            String   @id @default(uuid())
  tenantId      String
  unidadeId     String?
  placa         String
  renavam       String?
  chassi        String?
  modelo        String
  fabricante    String?
  anoFabricacao String?  @map("ano_fabricacao")
  categoria     String?
  status        String?  @default("Ativo")
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unidade Unidade? @relation(fields: [tenantId, unidadeId], references: [tenantId, id])
  seguros Seguro[]

  @@unique([tenantId, placa])
  @@unique([tenantId, renavam])
  @@unique([tenantId, id])
  @@index([tenantId, unidadeId])
  @@index([tenantId, status])
  @@index([tenantId, modelo])
  @@map("veiculos")
}

model Contrato {
  id             String         @id @default(uuid())
  tenantId       String
  numeroContrato String
  categoria      String?
  fornecedor     String?
  dataInicio     DateTime
  dataFim        DateTime
  status         StatusContrato @default(Ativo)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  anexos               Anexo[]
  equipamentosCobertos Equipamento[] @relation("ContratosEquipamentosCobertos")
  unidadesCobertas     Unidade[]     @relation("ContratosUnidadesCobertas")

  @@unique([tenantId, numeroContrato])
  @@unique([tenantId, id])
  @@index([tenantId, status, dataFim])
  @@index([tenantId, fornecedor])
  @@map("contratos")
}

model Manutencao {
  id                       String           @id @default(uuid())
  tenantId                 String
  numeroOS                 String           @map("numero_os")
  tipo                     TipoManutencao   @default(Preventiva) @map("tipo_manutencao")
  status                   StatusManutencao @default(Agendada)
  descricaoProblemaServico String?          @map("descricao_problema_servico")
  tecnicoResponsavel       String?          @map("tecnico_responsavel")
  numeroChamado            String?          @map("numero_chamado")
  solicitante              String?          @map("solicitante")
  origemAbertura           String?          @map("origem_abertura")

  agendamentoDataInicioLocal String? @map("agendamento_data_inicio_local")
  agendamentoHoraInicioLocal String? @map("agendamento_hora_inicio_local")
  agendamentoDataFimLocal    String? @map("agendamento_data_fim_local")
  agendamentoHoraFimLocal    String? @map("agendamento_hora_fim_local")
  agendamentoTimezone        String? @map("agendamento_timezone")

  dataHoraAgendamentoInicio DateTime? @map("data_hora_agendamento_inicio")
  dataHoraAgendamentoFim    DateTime? @map("data_hora_agendamento_fim")

  dataInicioReal DateTime? @map("data_inicio_real")
  dataFimReal    DateTime? @map("data_fim_real")
  dataConclusao  DateTime? @map("data_conclusao")
  custoTotal     Float?    @map("custo_total")
  equipamentoId  String    @map("equipamento_id")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento    Equipamento        @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)
  anexos         Anexo[]
  notasAndamento NotaAndamento[]
  eventos        ManutencaoEvento[]

  @@unique([tenantId, numeroOS])
  @@unique([tenantId, id])
  @@index([tenantId, equipamentoId])
  @@index([tenantId, status, dataHoraAgendamentoInicio])
  @@index([tenantId, status, dataHoraAgendamentoFim])
  @@index([tenantId, tipo, createdAt])
  @@index([tenantId, agendamentoDataInicioLocal])
  @@index([tenantId, agendamentoDataFimLocal])
  @@index([tenantId, agendamentoTimezone])
  @@map("manutencoes")
}

model ManutencaoEvento {
  id           String   @id @default(uuid())
  tenantId     String
  manutencaoId String   @map("manutencao_id")
  autorId      String?  @map("autor_id")
  tipo         String
  descricao    String?
  metadataJson String?  @db.Text
  dataEvento   DateTime @default(now()) @map("data_evento")
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manutencao Manutencao @relation(fields: [tenantId, manutencaoId], references: [tenantId, id], onDelete: Cascade)
  autor      Usuario?   @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([tenantId, manutencaoId, dataEvento])
  @@index([tenantId, tipo, dataEvento])
  @@map("manutencao_eventos")
}

model HistoricoAtivoEvento {
  id             String   @id @default(uuid())
  tenantId       String
  equipamentoId  String   @map("equipamento_id")
  tipoEvento     String   @map("tipo_evento")
  categoria      String
  subcategoria   String?
  titulo         String
  descricao      String?
  origem         String   @default("sistema")
  status         String?
  impactaAnalise Boolean  @default(false) @map("impacta_analise")
  referenciaId   String?  @map("referencia_id")
  referenciaTipo String?  @map("referencia_tipo")
  metadataJson   String?  @db.Text @map("metadata_json")
  dataEvento     DateTime @default(now()) @map("data_evento")
  createdAt      DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento Equipamento @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)

  @@index([tenantId, equipamentoId, dataEvento(sort: Desc)])
  @@index([tenantId, categoria, dataEvento(sort: Desc)])
  @@index([tenantId, impactaAnalise, dataEvento(sort: Desc)])
  @@index([tenantId, referenciaId, referenciaTipo])
  @@map("historico_ativo_eventos")
}

model Acessorio {
  id            String   @id @default(uuid())
  tenantId      String
  nome          String
  numeroSerie   String?  @map("numero_serie")
  descricao     String?
  equipamentoId String   @map("equipamento_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipamento Equipamento @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, numeroSerie])
  @@index([tenantId, equipamentoId])
  @@map("acessorios")
}

enum TipoSeguroProduto {
  EQUIPAMENTO
  PREDIAL
  AUTO
  RESPONSABILIDADE_CIVIL
  OUTRO
}

model Seguro {
  id                       String            @id @default(uuid())
  tenantId                 String
  tipoAlvo                 TipoSeguroAlvo    @default(EQUIPAMENTO)
  tipoSeguro               TipoSeguroProduto @default(EQUIPAMENTO)
  apoliceNumero            String            @map("apolice_numero")
  seguradora               String
  dataInicio               DateTime          @map("data_inicio")
  dataFim                  DateTime          @map("data_fim")
  status                   StatusSeguro      @default(Ativo)
  cobertura                String?
  equipamentoId            String?           @map("equipamento_id")
  unidadeId                String?           @map("unidade_id")
  veiculoId                String?           @map("veiculo_id")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  lmiAPP                   Float?            @default(0)
  lmiDanosCorporais        Float?            @default(0)
  lmiDanosEletricos        Float?            @default(0)
  lmiDanosMateriais        Float?            @default(0)
  lmiDanosMorais           Float?            @default(0)
  lmiIncendio              Float?            @default(0)
  lmiResponsabilidadeCivil Float?            @default(0)
  lmiRoubo                 Float?            @default(0)
  lmiVidros                Float?            @default(0)
  lmiVendaval              Float?            @default(0)
  lmiColisao               Float?            @default(0)
  lmiDanosCausaExterna     Float?            @default(0)
  lmiPerdaLucroBruto       Float?            @default(0)
  lmiVazamentoTanques      Float?            @default(0)
  premioTotal              Float?            @default(0) @map("premio_total")
  seguroAnteriorId         String?           @map("seguro_anterior_id")
  motivoCancelamento       String?           @map("motivo_cancelamento")

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  anexos         Anexo[]
  equipamento    Equipamento? @relation(fields: [tenantId, equipamentoId], references: [tenantId, id])
  unidade        Unidade?     @relation("SegurosUnidadesCobertas", fields: [tenantId, unidadeId], references: [tenantId, id])
  veiculo        Veiculo?     @relation(fields: [tenantId, veiculoId], references: [tenantId, id])
  seguroAnterior Seguro?      @relation("SeguroRenovacao", fields: [seguroAnteriorId], references: [id])
  renovacoes     Seguro[]     @relation("SeguroRenovacao")

  @@unique([tenantId, apoliceNumero])
  @@unique([tenantId, id])
  @@index([tenantId, tipoAlvo])
  @@index([tenantId, tipoSeguro])
  @@index([tenantId, status, dataFim])
  @@index([tenantId, seguradora])
  @@index([tenantId, equipamentoId])
  @@index([tenantId, unidadeId])
  @@index([tenantId, veiculoId])
  @@map("seguros")
}

model Alerta {
  id       String @id @default(uuid())
  tenantId String

  titulo        String
  subtitulo     String?
  subtituloBase String? @map("subtitulo_base")
  numeroOS      String? @map("numero_os")

  data                      DateTime
  dataHoraAgendamentoInicio DateTime? @map("data_hora_agendamento_inicio")
  dataHoraAgendamentoFim    DateTime? @map("data_hora_agendamento_fim")

  prioridade Prioridade

  tipo          String
  tipoCategoria String? @map("tipo_categoria")
  tipoEvento    String? @map("tipo_evento")

  link            String?
  emailEnviado    Boolean @default(false)
  telegramEnviado Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lidoPorUsuarios AlertaLidoPorUsuario[]

  @@unique([tenantId, id])
  @@index([tenantId, data])
  @@index([tenantId, tipo, data])
  @@index([tenantId, prioridade, data])
  @@index([tenantId, emailEnviado, createdAt(sort: Desc)])
  @@index([tenantId, telegramEnviado, createdAt(sort: Desc)])
  @@index([tenantId, numeroOS])
  @@index([tenantId, tipoEvento])
  @@index([tenantId, tipoCategoria])
  @@map("alertas")
}

model AlertaLidoPorUsuario {
  alertaId  String
  usuarioId String
  tenantId  String
  visto     Boolean   @default(true)
  dataVisto DateTime? @default(now())

  alerta  Alerta  @relation(fields: [tenantId, alertaId], references: [tenantId, id], onDelete: Cascade)
  usuario Usuario @relation(fields: [tenantId, usuarioId], references: [tenantId, id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([alertaId, usuarioId])
  @@index([tenantId, usuarioId, visto])
  @@map("alertas_lidos_por_usuario")
}

// Arquivo de auditoria: preserva alertas removidos pela retenção automática.
// IBM Maximo / MaintainX: toda ação do sistema deve ser rastreável.
model AlertaHistorico {
  id            String   @id @default(uuid())
  tenantId      String
  alertaId      String   @map("alerta_id")
  titulo        String
  subtitulo     String?
  tipo          String
  tipoCategoria String?  @map("tipo_categoria")
  tipoEvento    String?  @map("tipo_evento")
  prioridade    String
  link          String?
  numeroOS      String?  @map("numero_os")
  dataAlerta    DateTime @map("data_alerta")
  dataArquivado DateTime @default(now()) @map("data_arquivado")
  motivoArquivo String   @default("retencao_automatica") @map("motivo_arquivo")
  metadataJson  String?  @db.Text @map("metadata_json")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, dataAlerta(sort: Desc)])
  @@index([tenantId, tipo, dataAlerta(sort: Desc)])
  @@index([tenantId, tipoCategoria, dataAlerta(sort: Desc)])
  @@index([tenantId, prioridade, dataAlerta(sort: Desc)])
  @@index([tenantId, dataArquivado(sort: Desc)])
  @@map("alertas_historico")
}

model LogAuditoria {
  id         String   @id @default(uuid())
  tenantId   String
  acao       String
  entidade   String
  entidadeId String   @map("entidade_id")
  detalhes   String
  timestamp  DateTime @default(now())
  autorId    String   @map("autor_id")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  autor  Usuario @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([tenantId, entidade, entidadeId, timestamp])
  @@index([tenantId, autorId, timestamp])
  @@map("log_auditoria")
}

model Anexo {
  id            String   @id @default(uuid())
  tenantId      String
  nomeOriginal  String   @map("nome_original")
  path          String   @unique
  tipoMime      String   @map("tipo_mime")
  unidadeId     String?  @map("unidade_id")
  equipamentoId String?  @map("equipamento_id")
  manutencaoId  String?  @map("manutencao_id")
  seguroId      String?  @map("seguro_id")
  contratoId    String?  @map("contrato_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato    Contrato?    @relation(fields: [tenantId, contratoId], references: [tenantId, id], onDelete: Cascade)
  equipamento Equipamento? @relation(fields: [tenantId, equipamentoId], references: [tenantId, id], onDelete: Cascade)
  manutencao  Manutencao?  @relation(fields: [tenantId, manutencaoId], references: [tenantId, id], onDelete: Cascade)
  seguro      Seguro?      @relation(fields: [tenantId, seguroId], references: [tenantId, id], onDelete: Cascade)
  unidade     Unidade?     @relation(fields: [tenantId, unidadeId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, unidadeId])
  @@index([tenantId, equipamentoId])
  @@index([tenantId, manutencaoId])
  @@index([tenantId, seguroId])
  @@index([tenantId, contratoId])
  @@map("anexos")
}

model NotaAndamento {
  id            String   @id @default(uuid())
  tenantId      String
  nota          String
  data          DateTime @default(now())
  origem        String   @default("manual")
  manutencaoId  String?  @map("manutencao_id")
  osCorretivaId String?  @map("os_corretiva_id")
  autorId       String?  @map("autor_id")
  tecnicoNome   String?  @map("tecnico_nome")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  autor       Usuario?     @relation(fields: [autorId], references: [id], onDelete: SetNull)
  manutencao  Manutencao?  @relation(fields: [tenantId, manutencaoId], references: [tenantId, id], onDelete: Cascade)
  osCorretiva OsCorretiva? @relation(fields: [tenantId, osCorretivaId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, manutencaoId, data])
  @@index([tenantId, osCorretivaId, data])
  @@map("notas_andamento")
}

model EmailNotificacao {
  id                      String   @id @default(uuid())
  tenantId                String
  nome                    String?
  email                   String
  ativo                   Boolean  @default(true)
  diasAntecedencia        Int      @default(30)
  recebeAlertasContrato   Boolean  @default(true)
  recebeAlertasManutencao Boolean  @default(false)
  recebeAlertasSeguro     Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notificacoesEnviadas NotificacaoEnviada[]

  @@unique([tenantId, email])
  @@unique([tenantId, id])
  @@index([tenantId, ativo])
  @@map("emails_notificacao")
}

model NotificacaoEnviada {
  id                 String   @id @default(uuid())
  tenantId           String
  entidade           String
  entidadeId         String
  dataEnvio          DateTime @default(now())
  emailNotificacaoId String

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
